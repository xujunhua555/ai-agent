<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weeklyreport.mapper.EmailGroupMapper">
    <resultMap id="BaseResultMap" type="com.weeklyreport.entity.EmailGroup">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM email_group ORDER BY sort_order, id
    </select>
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM email_group WHERE id = #{id}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO email_group (name, sort_order)
        VALUES (#{name}, #{sortOrder})
    </insert>
    <update id="updateById">
        UPDATE email_group
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM email_group WHERE id = #{id}
    </delete>
</mapper>
